# =========================================================
# clinni pro · landing — variáveis de ambiente
# Copie para .env.local e preencha. Não commitar .env.local.
# =========================================================

# Supabase do PROJETO NOVO da landing (separado do app Prontool).
# Encontrar em: Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...service_role_secret...

# Go High Level — criação do contato direto pela API v2 (LeadConnector).
# Token: GHL → Settings → Private Integrations → Create → copie o token.
#        (precisa do escopo contacts.write)
GHL_API_TOKEN=
# ID da location/subconta de destino. GHL → Settings → Business Profile,
# ou na URL ao abrir a subconta (.../location/<LOCATION_ID>/...).
GHL_LOCATION_ID=
