# =========================================================
# clinni pro · landing — variáveis de ambiente
# Copie para .env.local e preencha. Não commitar .env.local.
# =========================================================

# Supabase do PROJETO NOVO da landing (separado do app Prontool).
# Encontrar em: Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...service_role_secret...

# Edge Function do Supabase que cria o lead no Go High Level.
# Ex.: https://YOUR-PROJECT-REF.supabase.co/functions/v1/ghl-create-lead
GHL_EDGE_FUNCTION_URL=
# Bearer enviado no header Authorization quando a Edge Function exige auth.
# Em geral é o ANON KEY do projeto Supabase, OU um secret próprio.
GHL_EDGE_FUNCTION_KEY=
